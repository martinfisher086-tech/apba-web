{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@layouts/*":    ["src/layouts/*"],
      "@lib/*":        ["src/lib/*"],
      "@styles/*":     ["src/styles/*"],
      "@types/*":      ["src/types/*"]
    },
    "strictNullChecks": true,
    "noImplicitAny": true,
    "allowJs": false
  },
  "include": ["src", "tests", "scripts"]
}
