---
import type { JournalIssue } from "@types/models";
import DownloadButton from "@components/molecules/DownloadButton.astro";

interface Props {
  issue: JournalIssue;
  headingLevel?: 2 | 3 | 4;
  class?: string;
}

const { issue, headingLevel = 3, class: className = "" } = Astro.props;
const Heading = `h${headingLevel}` as "h2" | "h3" | "h4";
---

<article class:list={["journal-card", className]}>
  {issue.coverImage && (
    <div class="card-cover">
      <img
        src={issue.coverImage.url}
        alt={issue.coverImage.alt ?? `Portada Gaceta Psicológica N° ${issue.number}`}
        loading="lazy"
        decoding="async"
        width="240"
        height="320"
      />
    </div>
  )}
  <div class="card-body">
    <span class="card-overline">N° {issue.number}</span>
    <Heading class="card-title">
      <a href={`/revistas/${issue.slug}/`}>{issue.title}</a>
    </Heading>
    {issue.publishDate && (
      <time class="card-date" datetime={issue.publishDate}>
        {new Date(issue.publishDate).toLocaleDateString("es-AR", { year: "numeric", month: "long" })}
      </time>
    )}
    {issue.description && <p class="card-desc">{issue.description}</p>}
    {issue.pdfFile && (
      <DownloadButton href={issue.pdfFile.url} label={`Descargar N° ${issue.number}`} />
    )}
  </div>
</article>

<style>
  .journal-card {
    display: flex;
    gap: var(--apba-space-4);
    padding: var(--apba-space-4);
    border: 1px solid var(--apba-border);
    border-radius: var(--apba-radius-lg);
    background: var(--apba-surface);
    transition: box-shadow var(--apba-motion-fast);
  }
  .journal-card:hover { box-shadow: var(--apba-shadow-md); }
  .card-cover { flex-shrink: 0; width: 80px; }
  .card-cover img { width: 100%; border-radius: var(--apba-radius-sm); box-shadow: var(--apba-shadow-sm); }
  .card-body { display: flex; flex-direction: column; gap: var(--apba-space-1); flex: 1; }
  .card-overline { font-size: var(--apba-text-overline); font-weight: var(--apba-weight-semibold); text-transform: uppercase; letter-spacing: 0.05em; color: var(--apba-brand-primary); }
  .card-title { font-size: var(--apba-text-body-lg); font-weight: var(--apba-weight-semibold); margin: 0; }
  .card-title a { color: var(--apba-text-primary); text-decoration: none; }
  .card-title a:hover { color: var(--apba-brand-primary); }
  .card-date { font-size: var(--apba-text-caption); color: var(--apba-text-tertiary); }
  .card-desc { font-size: var(--apba-text-body-sm); color: var(--apba-text-secondary); margin: var(--apba-space-1) 0 0; }
</style>
