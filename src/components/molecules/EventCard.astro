---
import type { Event } from "@types/models";
import Badge from "@components/atoms/Badge.astro";

interface Props {
  event: Event;
  headingLevel?: 2 | 3 | 4;
  class?: string;
}

const { event, headingLevel = 3, class: className = "" } = Astro.props;
const Heading = `h${headingLevel}` as "h2" | "h3" | "h4";

const isOnline = event.attendanceMode === "online";

const startDate = event.startDateTime
  ? new Date(event.startDateTime).toLocaleDateString("es-AR", {
      weekday: "short",
      day: "numeric",
      month: "short",
      year: "numeric",
    })
  : null;
---

<article class:list={["event-card", className]}>
  <div class="card-body">
    <div class="card-header">
      {event.type && <Badge variant="primary">{event.type}</Badge>}
      {isOnline && <Badge variant="default">Virtual</Badge>}
    </div>
    <Heading class="card-title">
      <a href={`/agenda/${event.slug}/`}>{event.title}</a>
    </Heading>
    {startDate && (
      <time class="card-date" datetime={event.startDateTime}>
        <span aria-hidden="true">📅</span>
        {startDate}
      </time>
    )}
    {event.location && event.location !== "online" && (
      <p class="card-location">
        <span aria-hidden="true">📍</span> {event.location}
      </p>
    )}
    {event.description && <p class="card-desc">{event.description}</p>}
  </div>
</article>

<style>
  .event-card {
    padding: var(--apba-space-4);
    border: 1px solid var(--apba-border);
    border-radius: var(--apba-radius-lg);
    background: var(--apba-surface);
    transition: box-shadow var(--apba-motion-fast);
  }
  .event-card:hover { box-shadow: var(--apba-shadow-md); }
  .card-header { display: flex; gap: var(--apba-space-2); margin-bottom: var(--apba-space-2); flex-wrap: wrap; }
  .card-title { font-size: var(--apba-text-body-lg); font-weight: var(--apba-weight-semibold); margin: 0 0 var(--apba-space-2); }
  .card-title a { color: var(--apba-text-primary); text-decoration: none; }
  .card-title a:hover { color: var(--apba-brand-primary); }
  .card-date, .card-location {
    font-size: var(--apba-text-body-sm);
    color: var(--apba-text-secondary);
    margin: 0 0 var(--apba-space-1);
  }
  .card-desc { font-size: var(--apba-text-body-sm); color: var(--apba-text-secondary); margin-top: var(--apba-space-2); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
