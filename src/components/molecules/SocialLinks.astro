---
interface SocialLink {
  platform: "facebook" | "instagram" | "twitter" | "youtube" | "linkedin";
  href: string;
}

interface Props {
  links: SocialLink[];
  class?: string;
}

const { links, class: className = "" } = Astro.props;

const labels: Record<string, string> = {
  facebook: "Facebook",
  instagram: "Instagram",
  twitter: "Twitter / X",
  youtube: "YouTube",
  linkedin: "LinkedIn",
};
---

<ul class:list={["social-links", className]} aria-label="Redes sociales">
  {links.map(({ platform, href }) => (
    <li>
      <a href={href} target="_blank" rel="noopener noreferrer" aria-label={`APBA en ${labels[platform]}`} class="social-link">
        {platform === "facebook" && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        )}
        {platform === "instagram" && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        )}
        {platform === "twitter" && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        )}
        {platform === "youtube" && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="#fff" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
        )}
        {platform === "linkedin" && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        )}
      </a>
    </li>
  ))}
</ul>

<style>
  .social-links { display: flex; gap: var(--apba-space-2); list-style: none; padding: 0; margin: 0; }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--apba-radius-full);
    color: currentColor;
    text-decoration: none;
    transition: background var(--apba-motion-fast), color var(--apba-motion-fast);
  }
  .social-link:hover { background: rgba(255,255,255,0.15); }
  .social-link:focus-visible { outline: 3px solid var(--apba-focus-ring); outline-offset: 2px; }
</style>
