---
interface Props {
  src?: string;
  alt?: string;
  name?: string;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { src, alt = "", name, size = "md", class: className = "" } = Astro.props;

const initials = name
  ? name.split(" ").slice(0, 2).map((n) => n[0]).join("").toUpperCase()
  : "?";
---

<div class:list={["avatar", `avatar--${size}`, className]} aria-hidden="true">
  {src
    ? <img src={src} alt={alt} loading="lazy" decoding="async" />
    : <span class="avatar-initials">{initials}</span>
  }
</div>

<style>
  .avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--apba-radius-full);
    background: var(--apba-brand-tint);
    color: var(--apba-brand-primary);
    overflow: hidden;
    flex-shrink: 0;
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; }
  .avatar-initials { font-weight: var(--apba-weight-semibold); line-height: 1; }
  .avatar--sm { width: 32px; height: 32px; font-size: var(--apba-text-caption); }
  .avatar--md { width: 44px; height: 44px; font-size: var(--apba-text-body-sm); }
  .avatar--lg { width: 64px; height: 64px; font-size: var(--apba-text-body-lg); }
</style>
