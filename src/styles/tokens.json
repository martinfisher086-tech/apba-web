{
  "$schema": "https://tr.designtokens.org/format/",
  "$metadata": {
    "project": "APBA — psicologos.org.ar",
    "version": "1.0.0-provisional",
    "status": "provisional — CP-4 required to confirm brand hex values and typeface pairing",
    "generatedBy": "Brief 2 — Design System Builder",
    "phase": "Phase 2"
  },

  "color": {
    "$type": "color",

    "brand": {
      "primary": {
        "$value": "#16519E",
        "$description": "Royal blue — APBA primary brand. Provisional; confirm from official logo SVG at CP-4.",
        "$status": "provisional"
      },
      "primaryStrong": {
        "$value": "#0E2F5C",
        "$description": "Navy — headers, footer, hero background, high-emphasis brand surfaces"
      },
      "accent": {
        "$value": "#C2185B",
        "$description": "Restrained magenta — echoes the logo gradient; used for primary CTAs (ASOCIATE, inscriptions) and key highlights. One-per-page-maximum principle.",
        "$status": "provisional"
      },
      "accentAlt": {
        "$value": "#16A0D8",
        "$description": "Cyan — secondary accent; journal tags, section accents, active states. Derived from logo gradient."
      }
    },

    "text": {
      "primary": {
        "$value": "#14202E",
        "$description": "Near-black for body text on light backgrounds. AAA on white."
      },
      "muted": {
        "$value": "#5A6B7B",
        "$description": "Secondary text: metadata, captions, placeholder. AA on white; verify."
      },
      "onBrand": {
        "$value": "#FFFFFF",
        "$description": "Text on brand-colored (primary/primaryStrong/accent) backgrounds."
      },
      "link": {
        "$value": "#16519E",
        "$description": "Same as brand.primary; underline required for non-hover state per WCAG."
      },
      "linkVisited": {
        "$value": "#7B3F9E",
        "$description": "Visited link state; purple-adjacent to preserve intent signal."
      }
    },

    "surface": {
      "base": {
        "$value": "#FFFFFF",
        "$description": "Page / default component background."
      },
      "raised": {
        "$value": "#F4F7FB",
        "$description": "Cards, panels, raised containers."
      },
      "sunken": {
        "$value": "#E9EFF6",
        "$description": "Inset wells, aside blocks, quote backgrounds."
      },
      "overlay": {
        "$value": "#14202E",
        "$description": "Modal/drawer backdrop at 60% opacity."
      }
    },

    "border": {
      "default": {
        "$value": "#D4DEE9",
        "$description": "Dividers, input borders, card borders."
      },
      "strong": {
        "$value": "#9EB4C8",
        "$description": "Emphasized separator."
      }
    },

    "feedback": {
      "success": { "$value": "#1E7F4F" },
      "successSurface": { "$value": "#E6F4EC" },
      "warning": { "$value": "#B26A00" },
      "warningSurface": { "$value": "#FFF3E0" },
      "error": { "$value": "#B3261E" },
      "errorSurface": { "$value": "#FCE8E6" },
      "info": { "$value": "#16519E" },
      "infoSurface": { "$value": "#E8F0FA" }
    },

    "focus": {
      "ring": {
        "$value": "#16A0D8",
        "$description": "Visible focus indicator. 3px solid, 2px offset. Never suppressed."
      }
    }
  },

  "typography": {
    "$description": "All font values assume Inter (Variable) as primary sans-serif. Display/heading serif pairing (Option A: Fraunces or Source Serif 4) requires CP-5 approval. Fallback stacks provided for system fonts during load.",

    "fontFamily": {
      "sans": {
        "$value": "'Inter Variable', 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
        "$description": "Primary typeface — body, UI, navigation."
      },
      "display": {
        "$value": "'Fraunces', 'Source Serif 4', Georgia, 'Times New Roman', serif",
        "$description": "Display/editorial typeface — H1, H2, hero headlines. Requires CP-5 sign-off on pairing choice.",
        "$status": "provisional"
      },
      "mono": {
        "$value": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
        "$description": "Code/technical strings (rarely used on this content site)."
      }
    },

    "fontSize": {
      "display": { "$value": "clamp(2.25rem, 4vw + 1rem, 3.5rem)", "$description": "Hero/home headline. Fluid." },
      "h1":      { "$value": "2.25rem",   "$description": "Page title. 36px base." },
      "h2":      { "$value": "1.75rem",   "$description": "Section heading. 28px." },
      "h3":      { "$value": "1.375rem",  "$description": "Card title / subsection. 22px." },
      "h4":      { "$value": "1.125rem",  "$description": "Minor heading. 18px." },
      "bodyLg":  { "$value": "1.125rem",  "$description": "Lead paragraph. 18px." },
      "body":    { "$value": "1rem",      "$description": "Default. 16px." },
      "bodySm":  { "$value": "0.875rem",  "$description": "Secondary. 14px." },
      "caption": { "$value": "0.75rem",   "$description": "Metadata, dates. 12px." },
      "overline":{ "$value": "0.75rem",   "$description": "Eyebrow labels. 12px uppercase tracked." }
    },

    "fontWeight": {
      "regular": { "$value": "400" },
      "medium":  { "$value": "500" },
      "semibold":{ "$value": "600" },
      "bold":    { "$value": "700" }
    },

    "lineHeight": {
      "tight":   { "$value": "1.05", "$description": "Display/hero" },
      "snug":    { "$value": "1.20", "$description": "H1–H2" },
      "normal":  { "$value": "1.30", "$description": "H3–H4" },
      "relaxed": { "$value": "1.5",  "$description": "Compact body / UI" },
      "loose":   { "$value": "1.6",  "$description": "Body text — long-form readability" }
    },

    "letterSpacing": {
      "tight":   { "$value": "-0.02em", "$description": "Display headings" },
      "normal":  { "$value": "0em" },
      "wide":    { "$value": "0.05em",  "$description": "Overline (uppercase)" },
      "wider":   { "$value": "0.10em",  "$description": "All-caps UI labels" }
    }
  },

  "spacing": {
    "$description": "Base unit 4px. Primary rhythm 8px. Scale: 0→1→2→3→4→6→8→12→16→24→32.",
    "0":  { "$value": "0rem" },
    "1":  { "$value": "0.25rem",  "$description": "4px" },
    "2":  { "$value": "0.5rem",   "$description": "8px — primary rhythm" },
    "3":  { "$value": "0.75rem",  "$description": "12px" },
    "4":  { "$value": "1rem",     "$description": "16px" },
    "5":  { "$value": "1.25rem",  "$description": "20px" },
    "6":  { "$value": "1.5rem",   "$description": "24px" },
    "8":  { "$value": "2rem",     "$description": "32px" },
    "10": { "$value": "2.5rem",   "$description": "40px" },
    "12": { "$value": "3rem",     "$description": "48px" },
    "16": { "$value": "4rem",     "$description": "64px" },
    "20": { "$value": "5rem",     "$description": "80px" },
    "24": { "$value": "6rem",     "$description": "96px" },
    "32": { "$value": "8rem",     "$description": "128px" }
  },

  "borderRadius": {
    "none":    { "$value": "0" },
    "sm":      { "$value": "4px",   "$description": "Subtle rounding — inputs, small chips" },
    "md":      { "$value": "6px",   "$description": "Buttons, inputs — primary interactive" },
    "lg":      { "$value": "8px",   "$description": "Cards, containers" },
    "xl":      { "$value": "12px",  "$description": "Large panels, modals" },
    "full":    { "$value": "9999px","$description": "Pills, tags, avatar rings only" }
  },

  "shadow": {
    "0": { "$value": "none",    "$description": "Flat — default card state" },
    "1": { "$value": "0 1px 2px 0 rgba(14,47,92,0.06)",   "$description": "Hairline — subtle lift" },
    "2": { "$value": "0 4px 12px 0 rgba(14,47,92,0.10)",  "$description": "Card hover / interactive element" },
    "3": { "$value": "0 8px 24px 0 rgba(14,47,92,0.14)",  "$description": "Modal, dropdown" },
    "4": { "$value": "0 16px 48px 0 rgba(14,47,92,0.18)", "$description": "Toast, top-level overlay" }
  },

  "motion": {
    "duration": {
      "fast":   { "$value": "120ms", "$description": "Micro-interactions: toggle, hover state" },
      "normal": { "$value": "180ms", "$description": "Standard transitions" },
      "slow":   { "$value": "240ms", "$description": "Panel open/close, page transitions" }
    },
    "easing": {
      "out":    { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$description": "Entrances" },
      "inOut":  { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$description": "State changes" },
      "in":     { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$description": "Exits" }
    }
  },

  "layout": {
    "containerMaxWidth": { "$value": "1280px" },
    "readingWidth":      { "$value": "72ch", "$description": "Long-form article column max-width" },
    "breakpoint": {
      "xs":  { "$value": "360px",  "$description": "Canonical mobile" },
      "sm":  { "$value": "480px",  "$description": "Large phones" },
      "md":  { "$value": "768px",  "$description": "Tablet — nav/layout shift" },
      "lg":  { "$value": "1024px", "$description": "Full mega-menu" },
      "xl":  { "$value": "1280px", "$description": "Desktop max container" },
      "2xl": { "$value": "1440px", "$description": "Large desktop" }
    }
  },

  "zIndex": {
    "base":    { "$value": "0" },
    "raised":  { "$value": "10" },
    "dropdown":{ "$value": "100" },
    "sticky":  { "$value": "200" },
    "modal":   { "$value": "300" },
    "toast":   { "$value": "400" }
  }
}
