---
import BaseLayout from "@layouts/BaseLayout.astro";
import ComingSoon from "@components/organisms/ComingSoon.astro";
import { getPageBySlug } from "@lib/cms";

const page = await getPageBySlug("docencia-e-investigacion");

const seo = {
  title: "Docencia e investigación — APBA",
  description: "Actividades de docencia e investigación de la Asociación de Psicólogas y Psicólogos de Buenos Aires.",
  noindex: false,
};
---

<BaseLayout {seo}>
  {page?.body ? (
    <div class="container page-layout">
      <nav aria-label="Ruta de navegación" class="breadcrumb">
        <ol>
          <li><a href="/">Inicio</a></li>
          <li><a href="/institucional/">Institucional</a></li>
          <li aria-current="page">Docencia e investigación</li>
        </ol>
      </nav>
      <h1>Docencia e investigación</h1>
      <div class="page-body" set:html={page.body} />
    </div>
  ) : (
    <ComingSoon
      title="Docencia e investigación"
      breadcrumbs={[
        { label: "Inicio", href: "/" },
        { label: "Institucional", href: "/institucional/" },
        { label: "Docencia e investigación" },
      ]}
      lead="Estamos actualizando la información sobre las actividades de docencia e investigación de APBA."
    />
  )}
</BaseLayout>

<style>
  .page-layout { padding-block: var(--apba-space-8) var(--apba-space-16); }
  .page-body { max-width: 72ch; }
</style>
