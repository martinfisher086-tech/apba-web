---
import BaseLayout from "@layouts/BaseLayout.astro";

const seo = {
  title: "Política de privacidad — APBA",
  description: "Política de privacidad y tratamiento de datos personales de psicologos.org.ar.",
  noindex: false,
};
---

<BaseLayout {seo}>
  <div class="container page-layout">
    <nav aria-label="Ruta de navegación" class="breadcrumb">
      <ol>
        <li><a href="/">Inicio</a></li>
        <li aria-current="page">Política de privacidad</li>
      </ol>
    </nav>

    <h1>Política de privacidad</h1>
    <p class="legal-notice">Estamos finalizando la redacción de nuestra política de privacidad, en conformidad con la Ley 25.326 de Protección de Datos Personales de la República Argentina. Para consultas sobre el tratamiento de tus datos, escribinos a <a href="mailto:apba@psicologos.org.ar">apba@psicologos.org.ar</a>.</p>

    <section class="policy-section">
      <h2>Responsable del tratamiento</h2>
      <p>Asociación de Psicólogas y Psicólogos de Buenos Aires (APBA)<br />
      <a href="mailto:apba@psicologos.org.ar">apba@psicologos.org.ar</a></p>
    </section>
  </div>
</BaseLayout>

<style>
  .page-layout { padding-block: var(--apba-space-8) var(--apba-space-16); max-width: 72ch; }
  .legal-notice { background: var(--apba-info-surface); color: var(--apba-info); padding: var(--apba-space-4); border-radius: var(--apba-radius-md); margin-bottom: var(--apba-space-8); }
  .policy-section { margin-top: var(--apba-space-8); }
  .policy-section h2 { font-size: var(--apba-text-h3); margin-bottom: var(--apba-space-3); }
</style>
