# ─── CMS (Sanity) ──────────────────────────────────────────────────────────
# Set via Vercel/Netlify/Cloudflare environment; never commit real values.
SANITY_PROJECT_ID=replace_with_project_id
SANITY_DATASET=production
SANITY_API_VERSION=2024-06-01
# Read-only token for build-time content fetching (not public)
SANITY_API_READ_TOKEN=

# ─── Forms / Transactional Email ───────────────────────────────────────────
RESEND_API_KEY=
FORM_NOTIFICATION_EMAIL=apba@psicologos.org.ar
HCAPTCHA_SECRET_KEY=    # or Turnstile secret
HCAPTCHA_SITE_KEY=      # public — safe to commit once chosen

# ─── Analytics (privacy-first, no cookies) ─────────────────────────────────
# Example: Plausible
PLAUSIBLE_DOMAIN=psicologos.org.ar

# ─── Google (scoped API key for Maps, if reinstated) ───────────────────────
GOOGLE_MAPS_API_KEY=    # RESTRICTED: referer psicologos.org.ar only

# ─── Build ─────────────────────────────────────────────────────────────────
# "production" | "staging" — affects robots.txt noindex
PUBLIC_ENV=staging
